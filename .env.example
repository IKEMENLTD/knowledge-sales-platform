# =============================================================================
# Knowledge Sales Platform — .env.example
# 仕様書 10_env_vars (v2) 準拠。Phase 区分:
#   P1必須   : Phase1 ローンチに必須
#   P1推奨   : Phase1 で投入推奨 (未投入でも起動はする)
#   P2       : Phase2 (Calendar / Gmail Pub/Sub / 通知運用)
#   P3       : Phase3 (A/B test / SRM 監視 / DR 訓練)
# -----------------------------------------------------------------------------
# 使い方:
#   1) cp .env.example .env.local
#   2) 値を埋める (本番値は絶対に commit しない)
#   3) Render Dashboard へは render.yaml の `sync: false` キーを個別に投入
#
# 注意:
#   - 機密値 (sk-, eyJ..., service-role key, secret token) は Supabase Vault /
#     Render Secret に投入し、git commit 禁止。.gitignore で .env* を除外済。
#   - rotation 中は `_PREVIOUS` 側に旧値を保持し、検証側で current/previous の
#     どちらでも通るようにする (dual-secret 7日窓 / 90日 rotation)。
#   - 値の `_PREVIOUS` を空文字にしておくと「rotation していない」状態。
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime / Mode (P1必須)
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
# Hono 起動モード (apps/worker)
#   ingress = HTTP webhook 受信サーバ
#   worker  = pgmq consumer 常駐
# Render では render.yaml で個別サービスごとに固定する。ローカル開発は ingress 推奨。
MODE=ingress

# -----------------------------------------------------------------------------
# Supabase (P1必須)
# Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # worker / Server Action 専用、ブラウザに漏らさない
SUPABASE_REGION=ap-northeast-1

# Drizzle migrate / worker 直接接続用
# Dashboard → Connect → Connection string (Transaction Pooler 6543 推奨)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Google OAuth (P1必須 — Auth callback)
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${APP_URL}/auth/callback
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxx

# Gmail Pub/Sub (P2 — Phase2 で日程調整 / メール同期)
GOOGLE_PUBSUB_TOPIC=

# Service Account (Vision API + Pub/Sub) (P1推奨 / P2)
# Render では Secret File として /etc/secrets/gcp-sa.json にマウント
GOOGLE_SERVICE_ACCOUNT_JSON=

# -----------------------------------------------------------------------------
# Zoom (P1必須)
# Marketplace で Server-to-Server OAuth App 作成
# WEBHOOK secret は 90日 rotation。current + previous の dual-secret window 7日。
# -----------------------------------------------------------------------------
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=
ZOOM_WEBHOOK_SECRET_TOKEN_PREVIOUS=  # rotation 中の旧 token (空でも可)

# -----------------------------------------------------------------------------
# Webhook secrets (P1必須)
# Gmail Pub/Sub 検証用。90日 rotation 同様。
# -----------------------------------------------------------------------------
WEBHOOK_SECRET_GMAIL=

# -----------------------------------------------------------------------------
# LLM (P1必須)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx

# -----------------------------------------------------------------------------
# Cloudflare R2 (P1必須 — 録画動画保管)
# private bucket、署名URLで配信。versioning + object lock 推奨。
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_RECORDINGS=ksp-recordings
R2_BUCKET_REGION=tokyo
R2_PUBLIC_DOMAIN=

# -----------------------------------------------------------------------------
# Notifications (P1推奨)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
SLACK_ALERT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Observability (P1必須)
# Sentry SDK 初期化フックは apps/worker/src/index.ts と apps/web/sentry.*.config.ts
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Rate limits / app behavior (P1必須)
# packages/shared/src/constants.ts の rateLimits(env) 関数で参照。
# -----------------------------------------------------------------------------
RATE_LIMIT_USER_RPM=60
RATE_LIMIT_ADMIN_RPM=10
MAX_OFFLINE_QUEUE_ITEMS=100
EMAIL_UNDO_WINDOW_SECONDS=30
RANKING_WEIGHTS=0.4,0.4,0.2

# -----------------------------------------------------------------------------
# pgmq / queue (P1必須)
# -----------------------------------------------------------------------------
# default visibility timeout (sec)。worker が consume してから ack せず timeout 切れると
# 同じ job が他 consumer に再配布される。重い job は read 時に上書き指定可。
PGMQ_VISIBILITY_TIMEOUT_DEFAULT=300

# -----------------------------------------------------------------------------
# Onboarding / sample data (P1必須)
# -----------------------------------------------------------------------------
SAMPLE_DATA_SEED=onboarding-seed-2026q2

# -----------------------------------------------------------------------------
# Backup / DR (P1必須)
# Supabase PITR window と soft-delete grace、cross-region backup 先。
# -----------------------------------------------------------------------------
PITR_WINDOW_DAYS=7
SOFT_DELETE_GRACE_DAYS=30
DR_BACKUP_REGION=ap-northeast-3   # Osaka. ap-northeast-1 障害時の WAL ship 先

# -----------------------------------------------------------------------------
# A/B test (P2)
# 22_feature_flags_ab: sha256(user_id + key + AB_HASH_SECRET) % 100 で stable hash
# -----------------------------------------------------------------------------
AB_HASH_SECRET=

# -----------------------------------------------------------------------------
# Auth / MFA (P1)
# 23_observability_alerts: MFA違反監視あり。admin/manager は MFA 必須。
# 値はカンマ区切りロール名 (small caps)。空にすると MFA 強制無効。
# -----------------------------------------------------------------------------
MFA_REQUIRED_FOR_ROLES=admin,manager
