# ============================================================================
# Knowledge Sales Platform — .env.example
# 仕様書: 10_env_vars シート準拠 (Phase1 必須を中心に)
# ----------------------------------------------------------------------------
# 使い方: cp .env.example .env.local して値を埋める
# 機密値は Render Dashboard / Supabase Vault に投入し、git commit しない
# ============================================================================

# ----- Runtime
NODE_ENV=development
APP_URL=http://localhost:3000

# ----- Supabase (P1必須)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # worker専用、ブラウザに漏らさない
SUPABASE_REGION=ap-northeast-1

# Drizzle migrate / Worker 直接接続用
# Dashboard → Connect → Connection string (Transaction Pooler 6543 推奨)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# ----- Google OAuth (P1)
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${APP_URL}/auth/callback
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxx
# Pub/SubはP2 (Gmail watch)
GOOGLE_PUBSUB_TOPIC=

# Service Account (Vision API + Pub/Sub)
# Render では Secret File として /etc/secrets/gcp-sa.json にマウント
GOOGLE_SERVICE_ACCOUNT_JSON=

# ----- Zoom (P1)
# Marketplace で Server-to-Server OAuth App 作成
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# ----- LLM (P1)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx

# ----- Cloudflare R2 (P1)
# 録画動画保管 (private bucket、署名URLで配信)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_RECORDINGS=ksp-recordings
R2_BUCKET_REGION=tokyo
R2_PUBLIC_DOMAIN=

# ----- Notifications (P1推奨)
RESEND_API_KEY=
SLACK_ALERT_WEBHOOK_URL=

# ----- Auth (P1)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ----- Observability
SENTRY_DSN=

# ----- Rate limits / app behavior (10_env_vars v2追加)
RATE_LIMIT_USER_RPM=60
RATE_LIMIT_ADMIN_RPM=10
MAX_OFFLINE_QUEUE_ITEMS=100
EMAIL_UNDO_WINDOW_SECONDS=30
RANKING_WEIGHTS=0.4,0.4,0.2
