{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "declaration": false,
    "paths": {
      "@/*": ["./src/*"],
      "@ksp/db": ["../../packages/db/src/index.ts"],
      "@ksp/db/*": ["../../packages/db/src/*"],
      "@ksp/shared": ["../../packages/shared/src/index.ts"],
      "@ksp/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
