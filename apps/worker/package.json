{
  "name": "@ksp/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-s3": "^3.689.0",
    "@aws-sdk/s3-request-presigner": "^3.689.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "@ksp/db": "workspace:*",
    "@ksp/shared": "workspace:*",
    "@sentry/node": "^8.38.0",
    "@supabase/supabase-js": "^2.46.1",
    "googleapis": "^144.0.0",
    "hono": "^4.6.10",
    "openai": "^4.71.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "resend": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
